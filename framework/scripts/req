#!/usr/bin/env python3
"""req — CLI for the req framework (PoC).

This is the first script-layer entry point for the req framework. It currently
implements only a single subcommand (`ask`) as a proof-of-concept for moving
decision-fork option generation from AI-interpreted markdown into deterministic
scripts.

Current subcommands:
    req ask <question-id> [--context <path>] [--var KEY=VALUE ...]

Future subcommands (not implemented in this PoC, listed for reference):
    req spec status <slug>
    req spec set-status <slug> <new-status>
    req spec check-prerequisites <slug>
    req review checklist <slug>
    req deploy pre-checks <slug>
    req brief render <command> <slug>
    req autonomy current | set <level>
    req changelog append <entry>
    req audit run

The PoC intentionally does NOT modify any existing /req-* command. It exists so
the framework can evaluate the "scripts generate option lists, AI does not
improvise" pattern before wider adoption.

Exit codes:
    0  success — JSON written to stdout
    1  usage error (bad arguments)
    2  unknown question id
    3  malformed catalog
    4  missing context file (dynamic question)
    5  dynamic extraction failed — fallback options were used (JSON still valid)
    10 missing dependency (PyYAML)
"""

import argparse
import json
import re
import sys
from pathlib import Path

try:
    import yaml
except ImportError:
    sys.stderr.write(
        "ERROR: PyYAML is required for `req ask`. Install with: pip install pyyaml\n"
    )
    sys.exit(10)


# ---------------------------------------------------------------------------
# Catalog loading
# ---------------------------------------------------------------------------

def find_framework_root():
    """Locate framework/ directory by walking up from this script's location.

    The script lives at framework/scripts/req, so the framework root is its
    parent directory. Fall back to searching upward for framework/config/
    in case the script is symlinked elsewhere.
    """
    script_path = Path(__file__).resolve()
    # script_path = .../framework/scripts/req → framework dir is parent.parent
    candidate = script_path.parent.parent
    if (candidate / "config" / "questions.yaml").is_file():
        return candidate
    # Fallback: walk upward from CWD looking for framework/config/questions.yaml
    for d in [Path.cwd().resolve(), *Path.cwd().resolve().parents]:
        if (d / "framework" / "config" / "questions.yaml").is_file():
            return d / "framework"
    sys.stderr.write(
        "ERROR: framework/config/questions.yaml not found. "
        "Run this from inside a req-framework repo.\n"
    )
    sys.exit(3)


def load_catalog():
    """Load and validate the questions catalog. Returns (catalog_dict, path)."""
    fw_root = find_framework_root()
    catalog_path = fw_root / "config" / "questions.yaml"
    try:
        with open(catalog_path, encoding="utf-8") as f:
            data = yaml.safe_load(f)
    except yaml.YAMLError as e:
        sys.stderr.write(f"ERROR: invalid YAML in {catalog_path}: {e}\n")
        sys.exit(3)
    if not isinstance(data, dict) or "catalog" not in data:
        sys.stderr.write(
            f"ERROR: malformed catalog at {catalog_path} "
            f"(expected top-level 'catalog:' mapping)\n"
        )
        sys.exit(3)
    catalog = data["catalog"]
    if not isinstance(catalog, dict):
        sys.stderr.write(
            f"ERROR: 'catalog' in {catalog_path} must be a mapping\n"
        )
        sys.exit(3)
    return catalog, catalog_path


# ---------------------------------------------------------------------------
# Static question handling
# ---------------------------------------------------------------------------

def format_static(entry, vars_map):
    """Format a static question entry into an AskUserQuestion JSON payload."""
    question = entry.get("question", "")
    if vars_map:
        try:
            question = question.format(**vars_map)
        except KeyError as e:
            sys.stderr.write(
                f"ERROR: static question references undefined template var {e}\n"
            )
            sys.exit(1)
    header = entry.get("header", "")
    if len(header) > 12:
        sys.stderr.write(
            f"WARNING: header '{header}' exceeds 12 chars; "
            f"AskUserQuestion will reject it\n"
        )
    multi = bool(entry.get("multi_select", False))
    options = []
    for o in entry.get("options", []) or []:
        if not isinstance(o, dict) or "label" not in o or "description" not in o:
            sys.stderr.write(
                f"ERROR: option malformed (need label + description): {o}\n"
            )
            sys.exit(3)
        options.append({"label": o["label"], "description": o["description"]})
    if not options:
        sys.stderr.write("ERROR: static question has no options\n")
        sys.exit(3)
    return {
        "questions": [
            {
                "question": question,
                "header": header,
                "multiSelect": multi,
                "options": options,
            }
        ]
    }


# ---------------------------------------------------------------------------
# Dynamic question handling — conflict_file source
# ---------------------------------------------------------------------------

CONFLICT_TITLE_RE = re.compile(r"^#\s*CONFLICT-\d+[：:]\s*(.+?)\s*$", re.MULTILINE)
POSSIBLE_SECTION_RE = re.compile(
    r"##\s*可能解決方向\s*\n(.+?)(?=\n##\s|\Z)", re.DOTALL
)
OPTION_BLOCK_RE = re.compile(
    r"###\s*Option\s*(\d+)[:：]\s*(.+?)\n(.+?)(?=\n###\s*Option\s|\Z)", re.DOTALL
)


def extract_conflict_title(text):
    m = CONFLICT_TITLE_RE.search(text)
    return m.group(1).strip() if m else None


def extract_conflict_options(text):
    """Extract resolution options from a CONFLICT-NNN.md body.

    Returns a list of {label, description} dicts, or None on failure.
    """
    section_match = POSSIBLE_SECTION_RE.search(text)
    if not section_match:
        return None
    section = section_match.group(1)
    options = []
    for m in OPTION_BLOCK_RE.finditer(section):
        num = m.group(1)
        title = m.group(2).strip().rstrip("*").strip()
        body = m.group(3).strip()
        description = _summarise_option_body(body)
        label = f"Option {num}：{title}"
        # Keep label short — AskUserQuestion labels should be 1-5 words
        if len(label) > 40:
            label = label[:37] + "..."
        options.append({"label": label, "description": description})
    return options if options else None


def _summarise_option_body(body):
    """Pick the first '做法' bullet or first non-empty line as description."""
    lines = [ln.strip() for ln in body.splitlines() if ln.strip()]
    # Prefer a '做法' line if present
    for ln in lines:
        if "做法" in ln:
            cleaned = re.sub(r"^[-*]\s*\**做法\**\s*[:：]?\s*", "", ln)
            cleaned = re.sub(r"\*\*", "", cleaned)
            return _truncate(cleaned)
    # Fall back to the first non-header, non-bullet-intro line
    for ln in lines:
        if ln.startswith("###") or ln.startswith("##"):
            continue
        cleaned = re.sub(r"^[-*]\s*", "", ln)
        cleaned = re.sub(r"\*\*", "", cleaned)
        if cleaned:
            return _truncate(cleaned)
    return ""


def _truncate(s, limit=120):
    return s if len(s) <= limit else s[: limit - 3] + "..."


def handle_dynamic(entry, context_path, vars_map):
    """Resolve a dynamic question. Returns (payload_dict, exit_code)."""
    source = entry.get("source")
    if source != "conflict_file":
        sys.stderr.write(
            f"ERROR: unsupported dynamic source '{source}' (only 'conflict_file' "
            f"implemented in PoC)\n"
        )
        sys.exit(3)
    if not context_path:
        sys.stderr.write(
            "ERROR: --context <path-to-CONFLICT-NNN.md> is required for "
            "resolve_conflict.picker\n"
        )
        sys.exit(4)
    cpath = Path(context_path)
    if not cpath.is_file():
        sys.stderr.write(f"ERROR: context file not found: {cpath}\n")
        sys.exit(4)
    text = cpath.read_text(encoding="utf-8")
    title = extract_conflict_title(text) or "衝突"
    options = extract_conflict_options(text)

    question_template = entry.get("question_template", "")
    try:
        question = question_template.format(title=title, **vars_map)
    except KeyError as e:
        sys.stderr.write(
            f"ERROR: dynamic question references undefined template var {e}\n"
        )
        sys.exit(1)
    header = entry.get("header", "")

    exit_code = 0
    if not options:
        sys.stderr.write(
            f"WARNING: could not extract resolution options from {cpath}; "
            f"using fallback options from catalog\n"
        )
        fallback = entry.get("fallback_options", []) or []
        options = [
            {"label": o["label"], "description": o["description"]}
            for o in fallback
            if isinstance(o, dict) and "label" in o and "description" in o
        ]
        if not options:
            sys.stderr.write(
                "ERROR: no fallback options defined and extraction failed\n"
            )
            sys.exit(3)
        exit_code = 5  # signal fallback-used but still valid

    payload = {
        "questions": [
            {
                "question": question,
                "header": header,
                "multiSelect": bool(entry.get("multi_select", False)),
                "options": options,
            }
        ]
    }
    return payload, exit_code


# ---------------------------------------------------------------------------
# Subcommand dispatch
# ---------------------------------------------------------------------------

def cmd_ask(args):
    catalog, catalog_path = load_catalog()
    if args.question_id not in catalog:
        sys.stderr.write(
            f"ERROR: unknown question id '{args.question_id}'\n"
            f"       Available ids in {catalog_path}:\n"
        )
        for k in sorted(catalog.keys()):
            sys.stderr.write(f"         - {k}\n")
        sys.exit(2)

    entry = catalog[args.question_id]
    if not isinstance(entry, dict):
        sys.stderr.write(
            f"ERROR: catalog entry '{args.question_id}' must be a mapping\n"
        )
        sys.exit(3)

    vars_map = {}
    for v in args.var or []:
        if "=" not in v:
            sys.stderr.write(f"ERROR: --var must be KEY=VALUE, got '{v}'\n")
            sys.exit(1)
        k, val = v.split("=", 1)
        vars_map[k] = val

    qtype = entry.get("type", "static")
    if qtype == "static":
        payload = format_static(entry, vars_map)
        exit_code = 0
    elif qtype == "dynamic":
        payload, exit_code = handle_dynamic(entry, args.context, vars_map)
    else:
        sys.stderr.write(f"ERROR: unknown question type '{qtype}'\n")
        sys.exit(3)

    json.dump(payload, sys.stdout, ensure_ascii=False, indent=2)
    sys.stdout.write("\n")
    sys.exit(exit_code)


def cmd_list(args):
    """List all available question ids in the catalog."""
    catalog, catalog_path = load_catalog()
    print(f"# Catalog: {catalog_path}")
    for qid in sorted(catalog.keys()):
        entry = catalog[qid]
        qtype = entry.get("type", "static")
        header = entry.get("header", "")
        print(f"  {qid:<35} [{qtype}] {header}")


# ---------------------------------------------------------------------------
# Autonomy subcommands
# ---------------------------------------------------------------------------

def find_host_root():
    """Walk upward from CWD to find .req.config.yml."""
    d = Path.cwd().resolve()
    while d != d.parent:
        if (d / ".req.config.yml").is_file():
            return d
        d = d.parent
    return None


def read_config_field(config_path: Path, field: str, default: str = "") -> str:
    """Read a top-level field from .req.config.yml (minimal YAML parser)."""
    if not config_path.is_file():
        return default
    for line in config_path.read_text(encoding="utf-8").splitlines():
        m = re.match(rf"^{re.escape(field)}\s*:\s*(.+)", line)
        if m:
            return m.group(1).strip().strip("'\"")
    return default


def write_config_field(config_path: Path, field: str, value: str):
    """Update or append a field in .req.config.yml."""
    text = config_path.read_text(encoding="utf-8")
    pattern = re.compile(rf"^({re.escape(field)}\s*:\s*)(.+)$", re.MULTILINE)
    if pattern.search(text):
        new_text = pattern.sub(rf"\g<1>{value}", text)
    else:
        new_text = text.rstrip() + f"\n{field}: {value}\n"
    config_path.write_text(new_text, encoding="utf-8")


def load_autonomy_matrix():
    """Load autonomy-matrix.yaml. Returns the parsed dict."""
    fw_root = find_framework_root()
    matrix_path = fw_root / "config" / "autonomy-matrix.yaml"
    if not matrix_path.is_file():
        sys.stderr.write(f"ERROR: {matrix_path} not found\n")
        sys.exit(3)
    with open(matrix_path, encoding="utf-8") as f:
        data = yaml.safe_load(f)
    return data, matrix_path


def format_matrix_table(matrix_data: dict, highlight_level: str = "") -> str:
    """Render the checkpoint matrix as a markdown table."""
    levels = matrix_data["levels"]
    checkpoints = matrix_data["checkpoints"]

    header = "| # | Checkpoint | " + " | ".join(f"L{i+1} {lv.capitalize()}" for i, lv in enumerate(levels)) + " |"
    sep = "|---|---|" + "|".join("---|" for _ in levels)

    rows = [header, sep]
    for i, cp in enumerate(checkpoints, 1):
        cells = [f"| {i}", cp["label_en"]]
        for lv in levels:
            beh = cp["behavior"].get(lv, {})
            actor = beh.get("actor", "human")
            if actor == "human":
                cell = "👤 Human"
            else:
                note = beh.get("note") or beh.get("condition") or "AI"
                cell = f"🤖 {note}"
            cells.append(cell)
        rows.append(" | ".join(cells) + " |")
    return "\n".join(rows)


def append_changelog(data_root: Path, entry: str):
    """Append a timestamped entry to docs/changelog.md."""
    changelog = data_root / "docs" / "changelog.md"
    changelog.parent.mkdir(parents=True, exist_ok=True)
    date = datetime.now().strftime("%Y-%m-%d")
    line = f"- {date}: {entry}\n"
    if changelog.is_file():
        text = changelog.read_text(encoding="utf-8")
        changelog.write_text(text.rstrip() + "\n" + line, encoding="utf-8")
    else:
        changelog.write_text(f"# Changelog\n\n{line}", encoding="utf-8")


def cmd_autonomy_current(args):
    """Display current autonomy level + checkpoint matrix."""
    host_root = find_host_root()
    if not host_root:
        sys.stderr.write("ERROR: .req.config.yml not found. Run req-init.sh first.\n")
        sys.exit(1)
    config = host_root / ".req.config.yml"
    current = read_config_field(config, "autonomy_level", "strict")

    matrix_data, _ = load_autonomy_matrix()
    valid_levels = matrix_data["levels"]
    if current not in valid_levels:
        sys.stderr.write(f"WARNING: unknown level '{current}', treating as strict\n")
        current = "strict"

    if args.format == "json":
        payload = {
            "level": current,
            "valid_levels": valid_levels,
            "checkpoints": [],
        }
        for cp in matrix_data["checkpoints"]:
            cp_out = {
                "id": cp["id"],
                "label": cp["label_en"],
                "command": cp["command"],
                "hard": cp["hard"],
                "actor": cp["behavior"][current]["actor"],
            }
            beh = cp["behavior"][current]
            if "condition" in beh:
                cp_out["condition"] = beh["condition"]
            if "note" in beh:
                cp_out["note"] = beh["note"]
            payload["checkpoints"].append(cp_out)
        json.dump(payload, sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print(f"Current autonomy level: **{current}**\n")
        print(format_matrix_table(matrix_data, current))
        safety = matrix_data.get("safety_net_note", "")
        if current != "strict" and safety:
            print(f"\n> {safety.strip()}")
    sys.exit(0)


def cmd_autonomy_set(args):
    """Change autonomy level: validate, update config, log changelog, print matrix."""
    matrix_data, _ = load_autonomy_matrix()
    valid_levels = matrix_data["levels"]
    new_level = args.level

    if new_level not in valid_levels:
        sys.stderr.write(
            f"ERROR: invalid level '{new_level}'. "
            f"Valid levels: {', '.join(valid_levels)}\n"
        )
        sys.exit(1)

    host_root = find_host_root()
    if not host_root:
        sys.stderr.write("ERROR: .req.config.yml not found. Run req-init.sh first.\n")
        sys.exit(1)

    config = host_root / ".req.config.yml"
    old_level = read_config_field(config, "autonomy_level", "strict")

    if old_level == new_level:
        sys.stderr.write(f"Autonomy level is already '{new_level}'. No change.\n")
        sys.exit(0)

    # Update config
    write_config_field(config, "autonomy_level", new_level)

    # Append changelog
    data_root_rel = read_config_field(config, "data_root", ".")
    data_root = host_root / data_root_rel
    append_changelog(data_root, f"autonomy level: {old_level} → {new_level} (via /req-autonomy)")

    if args.format == "json":
        payload = {
            "old_level": old_level,
            "new_level": new_level,
            "config_path": str(config),
            "changelog_appended": True,
        }
        if new_level == "auto":
            payload["warning"] = matrix_data.get("warnings", {}).get("auto", "")
        json.dump(payload, sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print(f"Autonomy level changed: {old_level} → **{new_level}**\n")
        print(format_matrix_table(matrix_data, new_level))
        warning = matrix_data.get("warnings", {}).get(new_level)
        if warning:
            print(f"\n{warning}")
        safety = matrix_data.get("safety_net_note", "")
        if new_level != "strict" and safety:
            print(f"\n> {safety.strip()}")

    sys.exit(0)


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

from datetime import datetime


def main():
    parser = argparse.ArgumentParser(
        prog="req",
        description="req framework CLI",
    )
    sub = parser.add_subparsers(dest="cmd", required=True)

    # --- ask ---
    ask = sub.add_parser(
        "ask",
        help="Resolve a question catalog entry into an AskUserQuestion JSON payload",
    )
    ask.add_argument("question_id", help="Question catalog id (e.g., review.approval)")
    ask.add_argument(
        "--context",
        help="Context file path (required for dynamic questions like resolve_conflict.picker)",
    )
    ask.add_argument(
        "--var",
        action="append",
        help="Template variable KEY=VALUE, repeatable",
    )
    ask.set_defaults(func=cmd_ask)

    # --- list ---
    lst = sub.add_parser("list", help="List all question ids in the catalog")
    lst.set_defaults(func=cmd_list)

    # --- autonomy ---
    autonomy_sub = sub.add_parser("autonomy", help="View or change autonomy level")
    autonomy_cmds = autonomy_sub.add_subparsers(dest="autonomy_cmd", required=True)

    auto_current = autonomy_cmds.add_parser("current", help="Show current level + matrix")
    auto_current.add_argument("--format", choices=["text", "json"], default="text")
    auto_current.set_defaults(func=cmd_autonomy_current)

    auto_set = autonomy_cmds.add_parser("set", help="Change autonomy level")
    auto_set.add_argument("level", help="New level: strict | balanced | auto")
    auto_set.add_argument("--format", choices=["text", "json"], default="text")
    auto_set.set_defaults(func=cmd_autonomy_set)

    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
